{
	"name": "detain/myadmin-webhosting-module",
	"type": "myadmin-plugin",
	"description": "Webhosting service module for the MyAdmin multiserver control panel. Provides automated provisioning, suspension, reactivation, and termination of shared hosting accounts across multiple hosting platforms including ISPconfig and ISPmanager.",
	"keywords": [
		"webhosting",
		"administration",
		"license",
		"myadmin",
		"hosting",
		"provisioning"
	],
	"license": "LGPL-2.1-only",
	"authors": [
		{
			"name": "Joe Huss",
			"homepage": "https://my.interserver.net/"
		}
	],
	"config": {
		"bin-dir": "vendor/bin",
		"minimum-stability": "dev",
		"allow-plugins": {
			"detain/myadmin-plugin-installer": true
		}
	},
	"require": {
		"php": ">=8.2",
		"ext-soap": "*",
		"symfony/event-dispatcher": "^5.0||^6.0||^7.0",
		"detain/myadmin-plugin-installer": "dev-master"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6"
	},
	"autoload": {
		"psr-4": {
			"Detain\\MyAdminWebhosting\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Detain\\MyAdminWebhosting\\Tests\\": "tests/"
		}
	}
}
